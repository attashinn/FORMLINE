# Database (Neon Postgres)
DATABASE_URL=
# Run `npm run db:migrate` after pulling — creates `owners` and `owner_settings` tables.

# Clerk auth
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_SIGN_IN_URL=/auth
CLERK_SIGN_UP_URL=/auth
CLERK_AFTER_SIGN_IN_URL=/dashboard
CLERK_AFTER_SIGN_UP_URL=/dashboard

# Public app URL (used for share links)
VITE_PUBLIC_APP_URL=https://formline.brnnd.com

# File storage (Supabase Storage — recommended for production)
# Create a bucket named "client-files" in your Supabase project (private bucket).
# Without these vars, uploads fall back to public/uploads/ on disk (fine for local dev;
# ephemeral on serverless hosts like Vercel — files are lost on redeploy).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (transactional email)
RESEND_API_KEY=
# Must be an email address on a verified domain in Resend for real client emails.
RESEND_FROM_EMAIL="Formline <forms@yourdomain.com>"

# Auth rate limiting / lockout (Upstash Redis — recommended for production)
# Falls back to in-memory cache when unset (local dev only; not shared across instances).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cron (weekly automation digest)
# Required in production. Generate with: openssl rand -hex 32
CRON_SECRET=
#
# Endpoint: GET /api/cron/weekly-summary
# Auth (production): Authorization: Bearer <CRON_SECRET>  OR  x-cron-secret: <CRON_SECRET>
# In development (NODE_ENV=development) the route is open for local testing.
#
# Vercel Cron (vercel.json):
#   {
#     "crons": [{
#       "path": "/api/cron/weekly-summary",
#       "schedule": "0 9 * * 1"
#     }]
#   }
# Set CRON_SECRET in Vercel project env, then use a protected cron route or
# Vercel's "Cron Secret" header if your plan supports it. Otherwise call from
# an external scheduler (GitHub Actions, cron-job.org) with:
#   curl -H "Authorization: Bearer $CRON_SECRET" https://your-domain.com/api/cron/weekly-summary
